{
  "name": "OPM Simulator Dev Environment",
  "build": {
    "dockerfile": "Dockerfile"
  },
  
  // Customizes settings and installs essential extensions inside the Codespace
  "customizations": {
    "vscode": {
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash",
        "cmake.configureOnOpen": true
      },
      "extensions": [
        "ms-vscode.cpptools",
        "ms-vscode.cpptools-extension-pack",
        "twxi.cmake",
        "ms-vscode.cmake-tools",
        "ms-python.python",
        "ms-python.vscode-pylance"
      ]
    }
  },

  // Runs commands after the container is created (e.g., verifying installations)
  "postCreateCommand": "flow --version || echo 'OPM Flow binary ready for development'",

  // Ensures you don't run as root unnecessarily
  "remoteUser": "vscode"
}
